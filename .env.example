# -------------------------------------------------------------------
# FRONTEND VARIABLES (PÚBLICAS)
# Estas variables son expuestas al cliente (Vite/React) de forma segura.
# Utilizan prefijo VITE_ para que el Bundler las incruste en build time.
# -------------------------------------------------------------------

# URL de tu API de Supabase (Settings -> API)
VITE_SUPABASE_URL="https://tu_proyecto.supabase.co"
# Clave pública "anon" de tu proyecto de Supabase (Diseñada para exponerse)
VITE_SUPABASE_ANON_KEY="tu_anon_key_publica_aqui"


# -------------------------------------------------------------------
# BACKEND VARIABLES (PRIVADAS)
# Estas variables son estrictamente consumidas por el servidor Node / Serveless.
# JAMÁS DEBEN LLEVAR EL PREFIJO VITE_. Configurarlas en el panel de Vercel.
# -------------------------------------------------------------------

# ===== BASE DE DATOS (PRISMA x SUPABASE) =====
# Conexión principal usando el Transaction Pooler de Supabase.
# CRÍTICO: Debe apuntar al puerto [6543] y terminar exhaustivamente con [?pgbouncer=true].
# Ejemplo: postgresql://postgres.abcdef:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.tu_proyecto:[PASSWORD]@[HOST]:[PORT_POOLER_6543]/postgres?pgbouncer=true"

# Conexión directa a la infraestructura. Exclusiva para Migraciones e Introspección (prisma db pull).
# CRÍTICO: Debe apuntar directo al clúster PostgreSQL en puerto nativo [5432] SIN pgbouncer.
# Ejemplo: postgresql://postgres.abcdef:[PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://postgres.tu_proyecto:[PASSWORD]@[HOST]:[PORT_DIRECT_5432]/postgres"


# ===== SERVICIOS DE TERCEROS (RESEND MAILER) =====
# Llave principal de la API generada en resend.com
RESEND_API_KEY="re_tus_credenciales_de_resend_api"

# Remitente validado bajo un dominio explícitamente verificado (DNS Records en Resend)
# Si no validas el dominio en sus settings, enviar correos a cuentas agenas fallará silenciosamente.
RESEND_FROM_EMAIL="Vital Pro <ventas@tudominio.com>"
